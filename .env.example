# ===============================================
# Configurações do Banco de Dados (PostgreSQL)
# ===============================================
POSTGRES_USER=queuebot_user
# MUDE ESTA SENHA EM PRODUÇÃO (SERVIDOR):
POSTGRES_PASSWORD=senha_super_segura_aqui
POSTGRES_DB=queuebot_db

# ===============================================
# Conexão do Backend com o Banco de Dados
# ===============================================
# IMPORTANTE: Os valores aqui devem corresponder exatamente aos valores definidos acima!
DATABASE_URL=postgres://queuebot_user:senha_super_segura_aqui@database:5432/queuebot_db

# ===============================================
# Configurações do REDIS
# ===============================================
REDIS_HOST=redis
REDIS_PORT=6379

# ===============================================
# Variáveis de Ambiente da Aplicação
# ===============================================
NODE_ENV=production
